# Copia a .env en esta carpeta (no subir credenciales).
#
# La URL debe ser https://TU-PROYECTO.supabase.co (con https://).
# También se leen NEXT_PUBLIC_* si aún no renombraste las variables de Next.
#
# Sin comillas en los valores (o con comillas, se normalizan).

EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Opcional: logs OAuth/PKCE en APK release (adb logcat). En __DEV__ ya están activos.
# EXPO_PUBLIC_AUTH_DEBUG=1

# URL pública HTTPS del sitio (invitaciones a equipos, enlaces de centro). Sin esto, las invitaciones usan el deep link nativo (expo.scheme).
EXPO_PUBLIC_SITE_URL=

# Política de privacidad pública (Play Console). La app también muestra /privacy-policy in-app.
# EXPO_PUBLIC_PRIVACY_POLICY_URL=https://www.sportmatch.cl/privacidad

# Cron push (solo servidor/CI — NO incluir en la app móvil ni en EAS Secrets del cliente).
# SUPABASE_URL=https://TU-PROYECTO.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=
# npm run notifications:dispatch   (cada 5–15 min vía GitHub Actions, Vercel Cron, etc.)

# Opcional: Sentry (errores y sesiones). Sin DSN, Sentry queda deshabilitado.
EXPO_PUBLIC_SENTRY_DSN=

# Opcional: para subir source maps en EAS Build (plugin @sentry/react-native/expo).
# SENTRY_AUTH_TOKEN se configura en EAS Secrets, no en .env del repo.
SENTRY_ORG=
SENTRY_PROJECT=sportmatch
